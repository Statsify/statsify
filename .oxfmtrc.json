{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "singleQuote": false,
  "trailingComma": "es5",
  "arrowParens": "always",
  "semi": true,
  "bracketSpacing": true,
  "ignorePatterns": [
    "**/dist/**",
    "**/node_modules/**",
    "**/.next/**",
    "**/pkg/**",
    ".turbo/**",
    "'.turbo'/**",
    "locales/**",
    ".github/**",
    "crowdin.yml",
    "**/*.css",
    "**/*.handlebars"
  ]
}

{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": ["pnpm.lock", "tsconfig.json", ".swcrc"],
  "ui": "tui",
  "tasks": {
    "build": {
      "env": ["API_URL", "API_KEY"],
      "outputs": ["dist/**", ".next/**", "pkg/**"],
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "outputs": [],
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "outputs": [],
      "dependsOn": ["build", "^test"]
    },
    "test:coverage": {
      "outputs": ["coverage"],
      "dependsOn": ["build", "^test:coverage"]
    },
    "lint": {
      "outputs": [],
      "dependsOn": []
    },
    "lint:ci": {
      "outputs": [],
      "dependsOn": []
    },
    "fmt": {
      "outputs": [],
      "dependsOn": []
    }
  }
}

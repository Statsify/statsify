{
  "name": "discord-bot",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node --enable-source-maps .",
    "build": "swc src --out-dir dist --strip-leading-paths",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint",
    "lint:ci": "oxlint --format=github"
  },
  "dependencies": {
    "@sentry/node": "^7.120.4",
    "@statsify/api-client": "workspace:^",
    "@statsify/assets": "workspace:^",
    "@statsify/discord": "workspace:^",
    "@statsify/logger": "workspace:^",
    "@statsify/math": "workspace:^",
    "@statsify/rendering": "workspace:^",
    "@statsify/schemas": "workspace:^",
    "@statsify/util": "workspace:^",
    "@swc/helpers": "^0.5.23",
    "@typegoose/typegoose": "^12.21.1",
    "axios": "1.18.1",
    "discord-api-types": "^0.38.49",
    "fuse.js": "^7.4.2",
    "luxon": "^3.7.2",
    "mongoose": "^8.24.1",
    "reflect-metadata": "^0.2.2",
    "skia-canvas": "3.0.8",
    "tiny-discord": "https://github.com/timotejroiko/tiny-discord.git#f6d020085ea88e33ebaf6ce323930deffe74fb0d",
    "typedi": "^0.10.0"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.2"
  },
  "imports": {
    "#components": {
      "types": "./src/components/index.ts",
      "default": "./dist/components/index.js"
    },
    "#commands/*": {
      "types": "./src/commands/*.ts",
      "default": "./dist/commands/*.js"
    },
    "#services": {
      "types": "./src/services/index.ts",
      "default": "./dist/services/index.js"
    },
    "#constants": {
      "types": "./src/constants.ts",
      "default": "./dist/constants.js"
    },
    "#themes": {
      "types": "./src/themes/index.ts",
      "default": "./dist/themes/index.js"
    },
    "#lib/*": {
      "types": "./src/lib/*.ts",
      "default": "./dist/lib/*.js"
    }
  }
}

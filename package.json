{
  "name": "statsify",
  "description": "",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Statsify/statsify.git"
  },
  "scripts": {
    "build": "turbo run build --filter=!site",
    "build:watch": "turbo watch build --filter=!site",
    "typecheck": "turbo run typecheck",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "turbo run lint",
    "lint:ci": "turbo run lint:ci",
    "fmt": "turbo run fmt",
    "api": "pnpm --filter api",
    "discord-bot": "pnpm --filter discord-bot",
    "support-bot": "pnpm --filter support-bot",
    "site": "pnpm --filter site",
    "scripts": "pnpm --filter scripts",
    "verify-server": "pnpm --filter verify-server"
  },
  "packageManager": "pnpm@10.34.1",
  "devDependencies": {
    "@j4cobi/eslint-plugin-sort-imports": "^1.0.2",
    "@napi-rs/cli": "^3.7.0",
    "@rollup/pluginutils": "^5.4.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "1.15.40",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260605.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "eslint-plugin-license-header": "^0.9.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "pm2": "^6.0.14",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "unplugin": "^3.0.0",
    "vitest": "^4.1.8"
  }
}
